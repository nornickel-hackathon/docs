      "confidence": 0.7,
      "evidence_type": "expert_note"
    },
    {
      "id": "claim_006",
      "text": "Zirconium can support thermally stable dispersoids and may partially substitute expensive scandium additions.",
      "source_ref": "doc_sc_alloys_notes",
      "confidence": 0.68,
      "evidence_type": "literature"
    },
    {
      "id": "claim_007",
