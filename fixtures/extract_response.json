      "id": "claim_001",
      "text": "Aging at elevated temperature changes the precipitate state in alloy 2618A and affects hardness.",
      "source_ref": "doc_aging_2618a",
      "confidence": 0.88,
      "evidence_type": "literature"
    },
    {
      "id": "claim_002",
      "text": "S-phase precipitates coarsen during long-term aging, which is linked to degradation of mechanical properties.",
      "source_ref": "doc_aging_2618a",
      "confidence": 0.86,
      "evidence_type": "literature"
    },
    {
      "id": "claim_003",
      "text": "Shorter aging windows can preserve finer precipitates and maintain higher hardness than overaged conditions.",
      "source_ref": "doc_internal_experiments",
      "confidence": 0.74,
      "evidence_type": "experiment"
    },
    {
      "id": "claim_004",
      "text": "Scandium-containing dispersoids can refine grain structure and contribute to strengthening in aluminum alloys.",
      "source_ref": "doc_sc_alloys_notes",
      "confidence": 0.82,
      "evidence_type": "literature"
    },
    {
      "id": "claim_005",
      "text": "Scandium additions are expensive and may exceed the target cost limit for low-margin process changes.",
